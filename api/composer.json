{
    "name": "sbsommar/api",
    "description": "PHP API for SB Sommar – shared hosting alternative to app.js",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/yaml": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SBSommar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SBSommar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
